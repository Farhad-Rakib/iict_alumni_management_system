# OS
.DS_Store

# Logs
*.log
logs/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Node
node_modules/
dist/
build/
coverage/

# Environment
.env
.env.*
!.env.*.template

# IDE
.vscode/
.idea/

# Project-specific secrets and local artifacts
credentials.json
uploads/

# Do not track prompts
PROMPTS/

# Local documentation and temporary files
# Ignore all markdown files by default
*.md
# But keep documentation in docs folder
docs/
docs/**/*.md
# Keep essential project documentation
!README.md
!tms_ui/README.md
!tms_ui/DEVELOPER_GUIDE.md
!tms_be/README.md

# Root level scripts and files (local only, don't commit)
!/*.sh
/*.zip
/*.json
!docker-compose*.yml
!.bolt/

# Exception for essential project files
!package.json
!package-lock.json
!tsconfig.json
!tsconfig.app.json
!tsconfig.node.json

# ignore mocks
/tms_ui/mocks/
/.tmp_admin_starter/
tmp_admin_starter
