# Database - Uses LOCAL PostgreSQL (NOT containerized)
# Make sure PostgreSQL is running on localhost:5432
# Setup: brew install postgresql@16 && createdb alumni_db
DATABASE_URL=postgresql+asyncpg://alumni_user:secure_password_change_me@localhost:5432/alumni_db
SQLALCHEMY_ECHO=False

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OTP
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6
VERIFICATION_LINK_EXPIRE_HOURS=72
MAX_OTP_ATTEMPTS=5

# Email
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SENDER_EMAIL=noreply@alumni.com

# Application
APP_NAME=Alumni Management System
APP_VERSION=1.0.0
DEBUG=False
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Redis (optional, for caching/rate limiting)
REDIS_URL=redis://localhost:6379/0

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880  # 5MB

# Pagination
DEFAULT_PAGE_SIZE=20
